      "variant": "react-router-framework-babel-lingui",
      "match": { "framework": "react-router-framework", "compiler": "babel", "library": "lingui" },
      "supportLevel": "stable",
      "appliesAlsoTo": [
        "The default React Router v7 scaffold does not install @vitejs/plugin-react — the reactRouter() plugin handles React internally. @vitejs/plugin-react@^5 is pinned (not ^6) because v6 dropped the babel.plugins option required for Lingui's Babel macro transform."
      ],
      "packages": {
        "runtime": ["@lingui/core@^6", "@lingui/react@^6"],
        "dev": ["@lingui/cli@^6", "@lingui/babel-plugin-lingui-macro@^6", "@lingui/vite-plugin@^6", "@vitejs/plugin-react@^5"]
