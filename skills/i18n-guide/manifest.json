  "incompatibleStacks": [
    {
      "match": { "library": "lingui", "router": "pages" },
      "reason": "LinguiJS setup currently does not cover the Next.js Pages Router. Use next-intl on Pages Router, or migrate to App Router."
    },
    {
      "match": { "framework": "cra" },
      "reason": "Create React App is no longer supported by this skill. Migrate to Vite or Next.js."
    },
    {
      "match": { "react": false, "vue": false, "svelte": false },
      "reason": "These skills currently target React-based, Vue-based, and Svelte-based projects only."
    }
