{
  "name": "@globalize-now/cli-client",
  "version": "0.1.8",
  "type": "module",
  "description": "CLI and library client for the Globalize translation platform",
  "bin": {
    "globalise-now-cli": "bin/globalise-now-cli.mjs"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "generate": "openapi-typescript ${GLOBALIZE_API_URL:-https://api.globalize.now}/api/docs/json -o src/api-types.ts",
    "build": "npm run generate && tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/ && prettier --check src/ && tsc --noEmit",
    "format": "eslint --fix src/ && prettier --write src/"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "openapi-fetch": "^0.13.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/globalize-now/globalize-skills.git",
    "directory": "api-client"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "openapi-typescript": "^7.6.0",
    "prettier": "^3.8.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.0"
  }
}
